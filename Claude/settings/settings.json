{
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npx wrangler *)",
      "Bash(npx eslint *)",
      "Bash(npx husky *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git stash *)",
      "Bash(op whoami)",
      "Bash(op run *)",
      "Bash(./verify_op.sh)",
      "Bash(node *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(chmod *)"
    ],
    "deny": [
      "Bash(git push *)",
      "Bash(git push)",
      "Bash(rm -rf *)",
      "Bash(wrangler deploy *)",
      "Bash(npx wrangler deploy *)",
      "Bash(npx wrangler secret *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'echo \"$CLAUDE_TOOL_INPUT_FILE_PATH\" | grep -qE \"^frontend/.*\\.js$\" && npx eslint \"$CLAUDE_TOOL_INPUT_FILE_PATH\" --max-warnings=0 || true'"
          }
        ]
      }
    ]
  }
}
